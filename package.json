{
  "name": "shipout",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "core",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @shipout/web",
    "dev:worker": "tsx --env-file=.env services/job-queue/consumer.ts",
    "worker": "tsx workers/static-analysis-worker/entrypoint.ts",
    "consumer": "tsx services/job-queue/consumer.ts",
    "build": "npm run build -w @shipout/web",
    "start": "npm run start -w @shipout/web",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "scan": "tsx apps/cli/src/index.ts",
    "clean": "npm run clean -w @shipout/web"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "chalk": "^5.6.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ip-cidr": "^4.0.2",
    "jose": "^6.1.3",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@vitest/ui": "^4.0.18",
    "eslint": "9.39.1",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  }
}