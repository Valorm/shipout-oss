{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "../../",
        "baseUrl": ".",
        "paths": {
            "@core/*": [
                "../../core/*"
            ],
            "@shared/*": [
                "../../packages/shared/*"
            ]
        }
    },
    "include": [
        "src/**/*",
        "../../core/**/*",
        "../../packages/shared/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}