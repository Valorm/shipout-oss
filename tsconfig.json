{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "baseUrl": ".",
    "paths": {
      "@core/*": [
        "core/*"
      ],
      "@shared/*": [
        "packages/shared/*"
      ],
      "@apps/*": [
        "apps/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "dist"
  ]
}