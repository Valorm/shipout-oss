# =============================================================================
# Shipout — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# =============================================================================

# --- Supabase (required) ---
# Find these in your Supabase project dashboard under Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # Keep server-side only

# --- Auth & Redirect (required for OAuth) ---
# The canonical URL of your deployed app. Used to build the GitHub OAuth redirect.
# In development: http://localhost:3000
# In production: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- AI Engine (required for full reports) ---
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# --- Cryptographic Signing (required in production) ---
# 32-byte hex string used to sign internal service identities (zero-trust layer).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-string

# --- GitHub Webhook (optional) ---
# Secret for validating push event webhooks from GitHub.
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# --- Fly.io Worker Dispatch (required for production scan execution) ---
# Obtain token from: fly auth token
FLY_API_TOKEN=your-fly-api-token
# The Fly.io app name for the ephemeral worker machines
FLY_APP_NAME=shipout-worker
# Docker image used for scan workers
WORKER_IMAGE=registry.fly.io/shipout-worker:latest
# Region to spawn worker machines in (e.g. iad, cdg, ewr)
FLY_REGION=iad

# --- Platform URL (optional) ---
# Used to build absolute callback URLs. Defaults to relative paths if unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# If the API and frontend are on different domains, set this:
# NEXT_PUBLIC_PLATFORM_URL=https://shipout-api.fly.dev
